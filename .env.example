# =========================================================
#  bot-x — Environment Variables
#  Copy to .env and fill in real values. Never commit .env.
# =========================================================

# ── App ──────────────────────────────────────────────────
APP_ENV=development           # development | staging | production
LOG_LEVEL=debug               # debug | info | warn | error
BASE_URL=http://localhost:8080

# ── Database (CockroachDB) ────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:26257/instantf?sslmode=disable

# ── Cache (Dragonfly / Redis) ─────────────────────────────
REDIS_URL=redis://localhost:6379

# ── ClickHouse (Audit Log) ────────────────────────────────
CLICKHOUSE_URL=clickhouse://localhost:9000
CLICKHOUSE_DB=instantf_audit

# ── HashiCorp Vault ───────────────────────────────────────
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=dev-root-token    # Dev mode only. Production uses AppRole.

# ── X (Twitter) API ───────────────────────────────────────
X_CONSUMER_KEY=your_consumer_key_here
X_CONSUMER_SECRET=your_consumer_secret_here
X_ACCESS_TOKEN=your_access_token_here
X_ACCESS_SECRET=your_access_secret_here
X_WEBHOOK_ENV=dev
X_BEARER_TOKEN=your_bearer_token_here
X_WEBHOOK_SECRET=your_webhook_secret_here
BOT_TWITTER_ID=your_bot_numeric_id_here
BOT_TWITTER_HANDLE=instantf_bot

# ── Safe Haven MFB ────────────────────────────────────────
# (Stored in Vault in production. Set here for local dev only.)
SAFEHAVEN_BASE_URL=https://api.safehavenmfb.com
SAFEHAVEN_CLIENT_ID=your_safehaven_client_id
SAFEHAVEN_CLIENT_SECRET=your_safehaven_client_secret
SAFEHAVEN_PRIVATE_KEY_PATH=   # Path to RS256 PEM file for JWT assertion

# ── Flutterwave ───────────────────────────────────────────
FLUTTERWAVE_SECRET_KEY=your_flutterwave_secret_key
FLUTTERWAVE_HASH_SECRET=your_flutterwave_hash_secret

# ── Paystack ─────────────────────────────────────────────
PAYSTACK_SECRET_KEY=your_paystack_secret_key
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret

# ── Stripe ───────────────────────────────────────────────
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
STRIPE_PLATFORM_ACCOUNT_ID=your_stripe_platform_id

# ── Crypto (Phase 3) ─────────────────────────────────────
CRYPTO_RPC_URL=               # Alchemy/QuickNode endpoint (Base mainnet)
CRYPTO_CHAIN_ID=8453          # 8453 = Base mainnet, 137 = Polygon
CRYPTO_TREASURY_VAULT_PATH=secret/crypto/treasury

# ── Admin ─────────────────────────────────────────────────
ADMIN_JWT_SECRET=your_jwt_secret_here
ADMIN_DUAL_APPROVAL_THRESHOLD_NGN=500000
ADMIN_DUAL_APPROVAL_THRESHOLD_USD=1000

# ── Internal Services (gRPC endpoints) ───────────────────
GRPC_XGATEWAY_ADDR=localhost:50051
GRPC_GIVEAWAY_ADDR=localhost:50052
GRPC_ENTRY_ADDR=localhost:50053
GRPC_PAYMENT_ROUTER_ADDR=localhost:50054
GRPC_KYC_ADDR=localhost:50055
GRPC_COMPLIANCE_ADDR=localhost:50056
GRPC_AUDIT_ADDR=localhost:50057
GRPC_NOTIFICATION_ADDR=localhost:50058
GRPC_RECONCILIATION_ADDR=localhost:50059

# ── PagerDuty / Alerting ──────────────────────────────────
PAGERDUTY_ROUTING_KEY=
SLACK_WEBHOOK_URL=

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_WEBHOOK_RPS=1000
RATE_LIMIT_API_RPS=100
MAX_ACTIVE_GIVEAWAYS_PER_HOST=5
