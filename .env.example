# =========================================================
#  bot-x — Environment Variables
#  Copy this to .env and fill in REAL values before deployment
# =========================================================

# ── Application ─────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=info
BASE_URL=https://twitter.instanttf.com
PORT=8080

# ── Infrastructure ────────────────────────────────────────
# Use your existing CockroachDB connection string here
DATABASE_URL=postgresql://botx_user:your_password@your-cluster.cockroachlabs.cloud:26257/instantf_bot_x?sslmode=verify-full

# These match the local containerized instances
REDIS_URL=redis://redis:6379
CLICKHOUSE_URL=clickhouse://clickhouse:9000
CLICKHOUSE_DB=instantf_audit
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=your_clickhouse_password

# ── Internal Networking (Docker) ──────────────────────────
GRPC_XGATEWAY_ADDR=xgateway:50051
GRPC_GIVEAWAY_ADDR=giveaway:50052
GRPC_ENTRY_ADDR=entry:50053
GRPC_PAYMENT_ROUTER_ADDR=payment-router:50054
GRPC_KYC_ADDR=kyc:50055
GRPC_COMPLIANCE_ADDR=compliance:50056
GRPC_AUDIT_ADDR=audit:50057
GRPC_NOTIFICATION_ADDR=notification:50058
GRPC_RECONCILIATION_ADDR=reconciliation:50059

# ── X (Twitter) API ─────────────────────────────────────
# Get these from https://developer.twitter.com/en/portal/dashboard
X_CONSUMER_KEY=your_consumer_key
X_CONSUMER_SECRET=your_consumer_secret
X_ACCESS_TOKEN=your_access_token
X_ACCESS_SECRET=your_access_secret
X_BEARER_TOKEN=your_bearer_token
X_WEBHOOK_SECRET=generate_random_webhook_secret
BOT_TWITTER_ID=your_bot_numeric_id
BOT_TWITTER_HANDLE=instantf_bot

# ── Safe Haven MFB (Nigeria Payments) ───────────────────
SAFEHAVEN_BASE_URL=https://api.safehavenmfb.com
SAFEHAVEN_CLIENT_ID=your_safehaven_client_id
SAFEHAVEN_CLIENT_SECRET=your_safehaven_client_secret
SAFEHAVEN_PRIVATE_KEY_PEM="-----BEGIN RSA PRIVATE KEY-----
MIIEowIBAAKCAQEA...
... your key content ...
-----END RSA PRIVATE KEY-----"

# ── Stripe (US/International Payments) ──────────────────
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key

# ── Admin Dashboard ─────────────────────────────────────
ADMIN_JWT_SECRET=generate_strong_jwt_secret_min_32_chars
ADMIN_DUAL_APPROVAL_THRESHOLD_NGN=500000
ADMIN_DUAL_APPROVAL_THRESHOLD_USD=1000

# ── Alerting (Optional but Recommended) ─────────────────
PAGERDUTY_ROUTING_KEY=
SLACK_WEBHOOK_URL=
