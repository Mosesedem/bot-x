# =========================================================
#  bot-x — Environment Variables
#  Copy to .env and fill in real values. Never commit .env.
# =========================================================

# ── App ──────────────────────────────────────────────────
APP_ENV=development           # development | staging | production
LOG_LEVEL=debug               # debug | info | warn | error
BASE_URL=http://localhost:8080

# ── Database (CockroachDB) ────────────────────────────────
DATABASE_URL=postgresql://root@localhost:26257/instantf?sslmode=disable

# ── Cache (Dragonfly / Redis) ─────────────────────────────
REDIS_URL=redis://localhost:6379

# ── ClickHouse (Audit Log) ────────────────────────────────
CLICKHOUSE_URL=clickhouse://localhost:9000
CLICKHOUSE_DB=instantf_audit

# ── HashiCorp Vault ───────────────────────────────────────
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=dev-root-token    # Dev mode only. Production uses AppRole.

# ── X (Twitter) API ───────────────────────────────────────
X_CONSUMER_KEY=onZwMRe5j4VjiSliDQUDEtM0J
X_CONSUMER_SECRET=W5v8ArRuiDTIQsbrkXF6wOcwZXpzumzVGWJt0yR007l3NfKUF3
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
X_WEBHOOK_ENV=dev
X_BEARER_TOKEN=AAAAAAAAAAAAAAAAAAAAAMBA9wEAAAAAm9mtsBLZUZdpzDA1BpfNNaLObn8%3DMGlElE7lHRBvBs64W280WqTgbNLkSezX44P7Ce5esvPe8acpK3
X_WEBHOOK_SECRET=             # Used for CRC + HMAC-SHA256 signature verification
BOT_TWITTER_ID=               # The @bot account's numeric Twitter user ID
BOT_TWITTER_HANDLE=instantf_bot

# ── Safe Haven MFB ────────────────────────────────────────
# (Stored in Vault in production. Set here for local dev only.)
SAFEHAVEN_BASE_URL=https://api.safehavenmfb.com
SAFEHAVEN_CLIENT_ID=
SAFEHAVEN_CLIENT_SECRET=
SAFEHAVEN_PRIVATE_KEY_PATH=   # Path to RS256 PEM file for JWT assertion

# ── Flutterwave ───────────────────────────────────────────
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_HASH_SECRET=      # For verif-hash webhook verification

# ── Paystack ─────────────────────────────────────────────
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=      # For x-paystack-signature verification

# ── Stripe ───────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=        # For stripe-signature verification
STRIPE_PLATFORM_ACCOUNT_ID=

# ── Crypto (Phase 3) ─────────────────────────────────────
CRYPTO_RPC_URL=               # Alchemy/QuickNode endpoint (Base mainnet)
CRYPTO_CHAIN_ID=8453          # 8453 = Base mainnet, 137 = Polygon
CRYPTO_TREASURY_VAULT_PATH=secret/crypto/treasury

# ── Admin ─────────────────────────────────────────────────
ADMIN_JWT_SECRET=678ihgcdrtyuikjnbvcxde67yuiokjhgvcde5678uikjnbvcdet67u8ikjnbvcdrty             # Symmetric secret for admin JWT signing
ADMIN_DUAL_APPROVAL_THRESHOLD_NGN=500000
ADMIN_DUAL_APPROVAL_THRESHOLD_USD=1000

# ── Internal Services (gRPC endpoints) ───────────────────
GRPC_XGATEWAY_ADDR=localhost:50051
GRPC_GIVEAWAY_ADDR=localhost:50052
GRPC_ENTRY_ADDR=localhost:50053
GRPC_PAYMENT_ROUTER_ADDR=localhost:50054
GRPC_KYC_ADDR=localhost:50055
GRPC_COMPLIANCE_ADDR=localhost:50056
GRPC_AUDIT_ADDR=localhost:50057
GRPC_NOTIFICATION_ADDR=localhost:50058
GRPC_RECONCILIATION_ADDR=localhost:50059

# ── PagerDuty / Alerting ──────────────────────────────────
PAGERDUTY_ROUTING_KEY=
SLACK_WEBHOOK_URL=

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_WEBHOOK_RPS=1000
RATE_LIMIT_API_RPS=100
MAX_ACTIVE_GIVEAWAYS_PER_HOST=5
